# ERP System Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://erp_user:secure_password_123@localhost:5432/erp_database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_database
DB_USER=erp_user
DB_PASSWORD=secure_password_123

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# ENCRYPTION & SECURITY
# ============================================
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_must_be_64_characters_total_abcd1234
ENCRYPTION_IV=your_16_byte_hex_iv_must_be_32_characters_total_abcd1234

# ============================================
# EMAIL CONFIGURATION (For notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@erpsystem.com

# ============================================
# GOOGLE SHEETS INTEGRATION (Optional)
# ============================================
GOOGLE_SHEETS_API_KEY=your_google_api_key
GOOGLE_SHEETS_ID=your_sheet_id

# ============================================
# AI/ML SERVICES
# ============================================
GOOGLE_AI_API_KEY=your_google_ai_api_key
AI_MODEL=gemini-pro

# ============================================
# CORS & FRONTEND
# ============================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# ============================================
# FILE UPLOAD
# ============================================
MAX_UPLOAD_SIZE=50mb
UPLOADS_DIR=./uploads

# ============================================
# BACKUP & RECOVERY
# ============================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/erp.log

# ============================================
# PAYMENT GATEWAY (Optional)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# ============================================
# CLOUD STORAGE (Optional - AWS S3)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# ============================================
# SENTRY ERROR TRACKING (Optional)
# ============================================
SENTRY_DSN=your_sentry_dsn
